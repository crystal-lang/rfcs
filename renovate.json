{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "separateMajorMinor": false,
  "packageRules": [
    {
      "groupName": "GH Actions",
      "matchManagers": [
        "github-actions"
      ],
      "schedule": [
        "after 5am and before 8am on Wednesday"
      ]
    }
  ],
  "labels": [
    "infrastructure"
  ]
}
